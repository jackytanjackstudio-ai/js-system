# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT ENVIRONMENT
# Copy this file to .env.local and fill in your DEV database URL.
#
# HOW TO GET A DEV DATABASE:
#   1. Go to https://console.neon.tech
#   2. Open your project → Branches → "New Branch"
#   3. Name it "dev", branch from "main"
#   4. Copy the connection string → paste as DATABASE_URL below
#
# RULES:
#   - .env.local is git-ignored — never commit real credentials
#   - NEVER put the production DATABASE_URL here
#   - ALLOW_SEED=true only works here (blocked everywhere else)
# ─────────────────────────────────────────────────────────────────────────────

DATABASE_URL="postgresql://neondb_owner:<password>@<dev-branch-host>.neon.tech/neondb?sslmode=require"

JWT_SECRET="jackstudio-os-dev-secret"

CLOUDINARY_CLOUD_NAME="ds0ka66z1"
CLOUDINARY_API_KEY="144196112372635"
CLOUDINARY_API_SECRET="5ZQzXxSbmRk2_yodGtkhm4jvBgM"

# Allows `npx prisma db seed` to run — DEV ONLY
ALLOW_SEED=true
