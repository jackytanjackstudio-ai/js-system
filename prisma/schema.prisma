generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("sales")
  outletId  String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outlet         Outlet?          @relation(fields: [outletId], references: [id])
  inputs         CustomerInput[]
  salesReports   SalesReport[]
  saleEntries    SaleEntry[]
  creatorContent CreatorContent[]
  rewardPoints   RewardPoint[]
  feedback       SystemFeedback[]
}

model Outlet {
  id         String   @id @default(cuid())
  name       String
  city       String
  type       String   @default("physical")
  channelKey String?
  region     String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  staff           User[]
  inputs          CustomerInput[]
  salesReports    SalesReport[]
  saleEntries     SaleEntry[]
  campaignOutlets CampaignOutlet[]
}

model CustomerInput {
  id            String   @id @default(cuid())
  userId        String
  outletId      String
  staffName     String?
  lookingFor    String   @default("[]")
  nobuReasons   String   @default("[]")
  suggestions   String   @default("[]")
  quote         String?
  week          String?
  month         Int?
  customerName  String?
  customerPhone String?
  imageUrl      String?
  imageTags     String   @default("[]")
  useCase       String   @default("[]")
  createdAt     DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  outlet Outlet @relation(fields: [outletId], references: [id])
}

model SalesReport {
  id            String   @id @default(cuid())
  userId        String
  outletId      String
  week          String
  salesDate     String?
  revenue       Float    @default(0)
  totalProfit   Float    @default(0)
  totalCogs     Float    @default(0)
  totalQty      Int      @default(0)
  topProducts   String   @default("[]")
  slowProducts  String   @default("[]")
  lineItems     String   @default("[]")
  warehouseName String?
  quote         String?
  objection     String?
  createdAt     DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  outlet Outlet @relation(fields: [outletId], references: [id])
}

model CreatorContent {
  id               String   @id @default(cuid())
  userId           String
  platform         String
  title            String
  contentUrl       String?
  contentType      String?
  productTags      String   @default("[]")
  views            Int      @default(0)
  likes            Int      @default(0)
  comments         Int      @default(0)
  saves            Int      @default(0)
  shares           Int      @default(0)
  linkedSales      Int      @default(0)
  topComment       String?
  productSignal    String?
  signalScore      Float    @default(0)
  aiSignals        String   @default("[]")
  pushedToWarRoom  Boolean  @default(false)
  week             String?
  month            Int?
  // V1 new fields
  objective        String   @default("traffic")
  dataSource       String   @default("manual")
  detectedKeywords String   @default("[]")
  performanceLevel String   @default("low")
  aiGenerated      Boolean  @default(false)
  productId        String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([performanceLevel])
  @@index([week])
}

model SaleEntry {
  id             String   @id @default(cuid())
  userId         String
  outletId       String
  productCode    String
  productName    String
  category       String
  useCase        String
  buyingTrigger  String
  customerType   String?
  lostReason     String?
  addOns         String   @default("[]")
  week           String
  month          Int
  createdAt      DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  outlet Outlet @relation(fields: [outletId], references: [id])
}

model Product {
  id              String   @id @default(cuid())
  name            String
  productCode     String?  @unique
  defaultUseCase  String?
  defaultTrigger  String?
  category        String
  status          String   @default("Sourcing")
  stage           String   @default("Bullet")
  hitRate      Float    @default(0)
  signalSource String?
  source       String   @default("customer")
  notes        String?
  decisionDate String?
  tasks        String   @default("[]")
  targetPrice  Float?
  cost         Float?
  imageUrl     String?
  imageUrls    String   @default("[]")
  useCase      String   @default("[]")
  style        String?
  material     String?
  colours      String   @default("[]")
  targetQty    Int?
  brand        String?
  promotions    String   @default("[]")
  sellingPoints String   @default("[]")
  demandScore   Float    @default(50)
  priority      String   @default("B")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  validations  SalesValidation[]
  reservations Reservation[]
}

model SalesValidation {
  id              String   @id @default(cuid())
  productId       String
  outletId        String
  outletName      String
  confidenceScore Int      @default(0)
  wouldSell       Boolean  @default(true)
  expectedSales   Int      @default(0)
  reason          String?
  staffName       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, outletId])
}

model Reservation {
  id               String   @id @default(cuid())
  productId        String
  outletId         String
  outletName       String
  quantity         Int      @default(0)
  colourBreakdown  String   @default("{}")
  signalTag        String?
  submittedBy      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, outletId])
}

model ExecutionTask {
  id        String   @id @default(cuid())
  title     String
  type      String
  assignee  String
  due       String
  status    String   @default("Not Started")
  result    String?
  productId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RewardPoint {
  id        String   @id @default(cuid())
  userId    String
  category  String
  points    Int
  reason    String
  weekRef   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model SystemFeedback {
  id        String   @id @default(cuid())
  userId    String
  week      String
  outlet    String?
  insight   String
  action    String?
  status    String   @default("pending")
  productId String?
  bonus     Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Campaign {
  id           String   @id @default(cuid())
  name         String
  type         String   @default("sales")
  startDate    String
  endDate      String
  channels     String   @default("[]")
  objective    String   @default("{}")
  mechanics    String   @default("[]")
  contentPlan  String   @default("{}")
  salesScript  String?
  status       String   @default("upcoming")
  scopeType    String   @default("all")
  scopeRegions String   @default("[]")
  owner        String   @default("hq")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vmGuide         VMGuide?
  tasks           CampaignTask[]
  submissions     VMSubmission[]
  campaignOutlets CampaignOutlet[]
}

model CampaignOutlet {
  id         String   @id @default(cuid())
  campaignId String
  outletId   String
  outletName String
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  outlet   Outlet   @relation(fields: [outletId], references: [id])

  @@unique([campaignId, outletId])
}

model VMGuide {
  id         String   @id @default(cuid())
  campaignId String   @unique
  images     String   @default("[]")
  checklist  String   @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignTask {
  id         String   @id @default(cuid())
  campaignId String
  outletId   String?
  taskName   String
  assignedTo String?
  deadline   String?
  status     String   @default("pending")
  category   String   @default("general")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model SkuCatalog {
  id        String   @id @default(cuid())
  stockCode String   @unique
  barcode   String?
  name      String
  brand     String?
  category  String
  price     Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([barcode])
}

model VMSubmission {
  id               String   @id @default(cuid())
  campaignId       String
  outletId         String
  outletName       String
  imageUrls        String   @default("[]")
  status           String   @default("pending")
  displayScore     Int?
  complianceScore  Int?
  cleanlinessScore Int?
  notes            String?
  submittedAt      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// ─── Product Master ────────────────────────────────────────────────────────────

model ProductMaster {
  id             String   @id @default(cuid())
  sku            String   @unique
  name           String
  // bag | belt | wallet | travel | accessory
  category       String
  // work | travel | daily | gift
  useCase        String
  // daily | core | pro
  series         String   @default("core")
  price          Float    @default(0)
  // selling | archive
  status         String   @default("selling")
  barcode        String?
  mainImageUrl   String?
  mediaFolderUrl String?
  sellingPoints        String   @default("[]")
  shortPitch           String?
  warRoomId            String?
  targetUser           String?
  customSellingPoints  String   @default("[]")
  salesPitch           String?
  material             String?
  style                String?
  generatedContent     Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  media ProductMedia[]

  @@index([status])
  @@index([category])
  @@index([useCase])
  @@index([sku])
}

model ProductMedia {
  id        String   @id @default(cuid())
  productId String
  type      String   @default("image")
  url       String
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product ProductMaster @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductTag {
  id   String @id @default(cuid())
  name String @unique

  tagMap ProductTagMap[]
}

model ProductTagMap {
  productId String
  tagId     String

  tag ProductTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
}

// ─── Incentive System ──────────────────────────────────────────────────────────

model WeightConfig {
  id         String   @id @default(cuid())
  name       String
  startDate  String   // YYYY-MM-DD
  endDate    String   // YYYY-MM-DD
  mposWeight Int      @default(50)
  // JSON: { quick_log: 25, content: 25, review: 25, campaign: 25 }
  osWeights  String   @default("{\"quick_log\":25,\"content\":25,\"review\":25,\"campaign\":25}")
  createdBy  String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  mposScores MposScore[]

  @@index([isActive])
}

model MposScore {
  id                 String       @id @default(cuid())
  outletId           String
  outletName         String
  periodId           String
  achievementPercent Float
  score              Int          // calculated: 100/80/60/40
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  period WeightConfig @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([outletId, periodId])
}

// ─── Data Hub Entry (unified signal layer) ─────────────────────────────────────

model DataHubEntry {
  id        String   @id @default(cuid())
  // "sales" | "customer_reason" | "content"
  type      String
  // product code / name as the shared key
  refId     String
  outletId  String
  value     Float    @default(1)
  // JSON: { productName, reason, useCase, source, week, ... }
  meta      String   @default("{}")
  week      String?
  month     Int?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([refId])
  @@index([outletId])
  @@index([week])
}

// ─── Seasonal Strategy Hub ─────────────────────────────────────────────────────

model SeasonalStrategy {
  id                String   @id @default(cuid())
  quarter           String   // "Q2 2026"
  theme             String   // "Urban Carry"
  heroProduct       String   // "Urban Carry Sling Bag"
  supportingItems   String   @default("[]") // JSON: ["Wallet","Belt","Backpack"]
  contentDirections String   @default("[]") // JSON: ["What's in my bag","Office carry"]
  vmDirection       String   @default("")   // "Urban café movement"
  keySignal         String   @default("")   // "Customer wants lightweight carry"
  backupStrategy    String   @default("")   // "If sling weak: push combo bundle"
  isActive          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─── Review Module ─────────────────────────────────────────────────────────────

model Review {
  id             String   @id @default(cuid())
  store          String
  rating         Int
  reviewText     String
  productTag     String
  createdAt      DateTime @default(now())
  usedForContent Boolean  @default(false)

  @@index([store])
  @@index([productTag])
}
